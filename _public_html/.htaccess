# Spencer's Website v7.0 - Hostinger/LiteSpeed .htaccess
# Security Overhaul â€” Full header suite, CORS, favicon, hardened rules
# ============================================================

# Explicit directory index
DirectoryIndex index.php index.html

# Custom error pages
# ErrorDocument 400 /errors/400.php
# ErrorDocument 401 /errors/401.php
# ErrorDocument 403 /errors/403.php
# ErrorDocument 404 /errors/404.php
# ErrorDocument 500 /errors/500.php
# ErrorDocument 503 /errors/503.php

# ============================================================
# FILE PROTECTION
# ============================================================

# Protect .env files
<FilesMatch "^\.env">
    Order allow,deny
    Deny from all
</FilesMatch>

# Protect database/backup/log files
<FilesMatch "\.(db|sqlite|sqlite3|bak|sql|log|quarantine)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Protect package manager and git files
<FilesMatch "^(\.git|\.gitignore|composer\.(json|lock)|package\.(json|lock))$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Protect ALL markdown and text documentation files from web access
<FilesMatch "\.(md|txt)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Disable directory browsing
Options -Indexes

# Disable server signature
ServerSignature Off

# ============================================================
# HTTPS & CANONICAL REDIRECTS
# ============================================================
<IfModule mod_rewrite.c>
    RewriteEngine On

    # ACME challenge passthrough (must come FIRST before any blocking rules)
    RewriteRule ^\.well-known/ - [L]

    # Force HTTPS (Hostinger/Cloudflare proxy aware)
    RewriteCond %{HTTP:X-Forwarded-Proto} !https [OR]
    RewriteCond %{HTTPS} off
    RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]

    # Canonical: www â†’ non-www
    RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
    RewriteRule ^(.*)$ https://%1/$1 [R=301,L]

    # Favicon redirect: /favicon.ico â†’ /assets/images/favicon.webp
    RewriteRule ^favicon\.ico$ /assets/images/favicon.webp [L,R=301]

    # ============================================================
    # ATTACK BLOCKING
    # ============================================================

    # SQL Injection patterns
    RewriteCond %{QUERY_STRING} (\%27|\'|--|\%23|#|union|select|insert|drop|delete|update|concat|load_file|benchmark|sleep) [NC,OR]
    RewriteCond %{QUERY_STRING} (base64_encode|union\s+select|union\s+all\s+select|concat.*\() [NC]
    RewriteRule ^(.*)$ - [F,L]

    # XSS/Script injection
    RewriteCond %{QUERY_STRING} (\<|%3C).*script.*(\>|%3E) [NC,OR]
    RewriteCond %{QUERY_STRING} GLOBALS(=|\[|\%[0-9A-Z]{0,2}) [OR]
    RewriteCond %{QUERY_STRING} _REQUEST(=|\[|\%[0-9A-Z]{0,2})
    RewriteRule ^(.*)$ - [F,L]

    # Block malicious user agents
    RewriteCond %{HTTP_USER_AGENT} (havij|sqlmap|nikto|nessus|dirbuster|whatweb|w3af|scanner|nmap) [NC]
    RewriteRule ^(.*)$ - [F,L]

    # Block WordPress attack paths
    RewriteRule ^(wp-admin|wp-login|wp-content|xmlrpc\.php) - [F,L]

    # Block dotfiles (AFTER .well-known exclusion above)
    RewriteRule (^\.|/\.) - [F,L]
</IfModule>

# ============================================================
# SECURITY HEADERS (Global â€” applies to ALL responses)
# ============================================================
<IfModule mod_headers.c>
    # --- Force correct MIME types for static assets (fixes LiteSpeed serving CSS as text/html) ---
    <FilesMatch "\.css$">
        Header set Content-Type "text/css; charset=utf-8"
    </FilesMatch>
    <FilesMatch "\.js$">
        Header set Content-Type "application/javascript; charset=utf-8"
    </FilesMatch>

    # --- Core Security Headers ---
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set X-Permitted-Cross-Domain-Policies "none"

    # --- HSTS: 2-year max-age with subdomains and preload ---
    Header always set Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"

    # --- Permissions-Policy (privacy-focused: disable tracking features) ---
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(self), usb=(), xr-spatial-tracking=(), interest-cohort=(), browsing-topics=(), attribution-reporting=(), run-ad-auction=(), join-ad-interest-group=()"

    # --- Content-Security-Policy (with upgrade-insecure-requests) ---
    # v7.1: Font Awesome self-hosted from /assets/vendor/fontawesome/. Dropped
    # cdnjs.cloudflare.com from font-src (no longer needed). Added object-src,
    # base-uri, form-action, frame-ancestors hardening.
    Header always set Content-Security-Policy "upgrade-insecure-requests; default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://cdnjs.cloudflare.com https://challenges.cloudflare.com https://rawcdn.githack.com https://www.google.com https://www.gstatic.com https://accounts.google.com https://apis.google.com; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://cdnjs.cloudflare.com https://fonts.googleapis.com https://www.google.com https://challenges.cloudflare.com; font-src 'self' https://fonts.gstatic.com https://fonts.googleapis.com data:; img-src 'self' data: blob: https://www.google.com https://www.gstatic.com https://cdn.jsdelivr.net https://cdnjs.cloudflare.com; connect-src 'self' https://api.groq.com https://challenges.cloudflare.com https://www.google.com https://accounts.google.com https://cdn.jsdelivr.net; frame-src 'self' https://challenges.cloudflare.com https://searchprox.global.ssl.fastly.net https://thespencergamingwebsite.com https://*.voidnetwork.space.cdn.cloudflare.net https://c.voidnetwork.space.cdn.cloudflare.net https://archive.org https://rawcdn.githack.com https://www.google.com https://accounts.google.com; frame-ancestors 'none'; base-uri 'self'; object-src 'none'; form-action 'self'; worker-src 'self' blob:; report-uri /api/csp-violation"

    # --- Cross-Origin Policies ---
    Header always set Cross-Origin-Opener-Policy "same-origin"
    Header always set Cross-Origin-Resource-Policy "same-site"

    # --- CORS for Google Fonts (fixes signature-agent block) ---
    <FilesMatch "\.(woff|woff2|ttf|otf|eot)$">
        Header set Access-Control-Allow-Origin "*"
        Header set Access-Control-Allow-Headers "Origin, X-Requested-With, Content-Type, Accept, signature-agent"
        Header set Access-Control-Allow-Methods "GET, OPTIONS"
    </FilesMatch>

    # --- Remove X-Powered-By if PHP leaks it despite .user.ini ---
    Header always unset X-Powered-By
    Header unset X-Powered-By
</IfModule>

# ============================================================
# CACHING
# ============================================================
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresDefault "access plus 1 month"
    ExpiresByType text/html "access plus 0 seconds"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/x-icon "access plus 1 year"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType application/json "access plus 0 seconds"
</IfModule>

# ============================================================
# COMPRESSION
# ============================================================
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css
    AddOutputFilterByType DEFLATE application/javascript text/javascript
    AddOutputFilterByType DEFLATE application/json
    AddOutputFilterByType DEFLATE font/woff font/woff2
    AddOutputFilterByType DEFLATE application/wasm application/octet-stream
</IfModule>

# Explicit MIME types (prevents server misconfiguration serving CSS/JS as text/html)
AddType text/css .css
AddType application/javascript .js
AddType application/json .json

# WebGL MIME types for Unity/game assets
AddType application/wasm .wasm
AddType application/octet-stream .data .unityweb
AddType application/javascript .loader.js .framework.js

# Serve precompressed .br or .gz files if they exist and client accepts them
<IfModule mod_rewrite.c>
    RewriteCond %{HTTP:Accept-Encoding} br
    RewriteCond %{REQUEST_FILENAME}.br -f
    RewriteCond %{REQUEST_URI} \.(css|js|html|svg|json|wasm)$
    RewriteRule ^(.+)$ $1.br [L,E=encoding:brotli]
    
    RewriteCond %{HTTP:Accept-Encoding} gzip
    RewriteCond %{REQUEST_FILENAME}.gz -f
    RewriteCond %{REQUEST_URI} \.(css|js|html|svg|json|wasm)$
    RewriteRule ^(.+)$ $1.gz [L,E=encoding:gzip]
</IfModule>

<IfModule mod_headers.c>
    # Set correct encoding headers for precompressed files
    Header set Content-Encoding br env=encoding:brotli
    Header set Content-Encoding gzip env=encoding:gzip
    
    # Static asset aggressive caching (versioned via ?v=<hash> query string)
    # <If "%{REQUEST_URI} =~ m#^/(js|css|assets)/#">
    #     Header set Cache-Control "public, max-age=31536000, immutable"
    # </If>
    
    # Cache fonts for 1 year (immutable, versioned by filename)
    <FilesMatch "\.(woff2?|ttf|otf|eot)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
    
    # Cache images for 30 days (can be bumped to 1y if versioned)
    <FilesMatch "\.(png|jpg|jpeg|gif|svg|webp|ico)$">
        Header set Cache-Control "public, max-age=2592000"
    </FilesMatch>
</IfModule>

# Default charset
AddDefaultCharset UTF-8
# php_value default_charset "UTF-8"

# ============================================================
# PHP SETTINGS (Hostinger â€” LiteSpeed may use .user.ini instead)
# ============================================================
